SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SESSION_SECRET=generate-a-long-random-secret-minimum-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override default bucket names.
BOOK_FILES_BUCKET=book-files
BOOK_COVERS_BUCKET=book-covers

# Optional: Cloudflare R2. If all R2 values are filled, new uploads use R2.
# Existing Supabase Storage files keep working through storage_provider metadata.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=maktabah-files
UPLOAD_STORAGE_PROVIDER=auto
